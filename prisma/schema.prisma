generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== CONFIGURACIÓN FRIGORÍFICO ====================

model ConfiguracionFrigorifico {
  id                      String   @id @default(cuid())
  nombre                  String   @default("Solemar Alimentaria")
  direccion               String?
  numeroEstablecimiento   String?  // N° Establecimiento Oficial
  cuit                    String?
  numeroMatricula         String?  // N° Matrícula
  logo                    String?  // URL del logo (logo.png)
  
  // Configuración de emails
  emailHost               String?  // smtp.office365.com
  emailPuerto             Int?     @default(587)
  emailUsuario            String?  // usuario@solemar.com.ar
  emailPassword           String?  // Encriptado
  emailHabilitado         Boolean  @default(false)
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ==================== CORRALES ====================

model Corral {
  id          String   @id @default(cuid())
  nombre      String   @unique
  capacidad   Int      @default(0)
  observaciones String?
  activo      Boolean  @default(true)
  
  // Stock actual
  stockBovinos  Int    @default(0)
  stockEquinos  Int    @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  movimientosOrigen   MovimientoCorral[]  @relation("CorralOrigen")
  movimientosDestino  MovimientoCorral[]  @relation("CorralDestino")
  tropas              Tropa[]
}

// ==================== CÁMARAS ====================

model Camara {
  id            String        @id @default(cuid())
  nombre        String        @unique
  tipo          TipoCamara    @default(FAENA)
  capacidad     Int           @default(0)  // Ganchos o KG según tipo
  observaciones String?
  activo        Boolean       @default(true)
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  movimientosOrigen   MovimientoCamara[]  @relation("CamaraOrigen")
  movimientosDestino  MovimientoCamara[]  @relation("CamaraDestino")
  stockMedias         StockMediaRes[]
  mediasRes           MediaRes[]
}

enum TipoCamara {
  FAENA      // Capacidad en ganchos
  CUARTEO    // Capacidad en KG
  DEPOSITO   // Capacidad en KG
}

// ==================== TIPIFICADORES ====================

model Tipificador {
  id            String   @id @default(cuid())
  nombre        String
  apellido      String
  numero        String?  // Número interno
  matricula     String   @unique  // Número de matrícula (se usa en rótulos)
  activo        Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  romaneos      Romaneo[]
}

// ==================== PRODUCTOS ====================

model Producto {
  id                    String          @id @default(cuid())
  codigo                String          // Código de artículo (3 dígitos)
  codigoSecundario      String?         // Segundo código (campo azul en la imagen)
  nombre                String
  
  // Datos técnicos
  tara                  Float?          // Peso tara
  vencimiento           Int?            // Días de vencimiento (VTO)
  nroSenasa             String?         // Número SENASA
  unidad                String?         // Unidad de medida (kg, unidades, etc.)
  cantidadEtiquetas     Int?            // CANT ETI - cantidad de etiquetas
  
  // Tipificación
  tieneTipificacion     Boolean         @default(false)
  tipificacion          String?         // Código de tipificación
  tipificacionSecundaria String?        // Segundo campo de tipificación
  
  // Tipo de producto
  tipo                  String?         // Tipo de producto
  tipoGeneral           String?         // TIPO GRAL
  
  // Descripción y precios
  descripcionCircular   String?         // DESCRI. CIRCULAR
  precioDolar           Float?          // P.DOLAR
  precioEuro            Float?          // P.EURO
  
  // Producción
  producidoParaCliente  String?         // Cliente para quien se produce
  producidoDePieza      String?         // Pieza de origen
  productoGeneral       String?         // Producto general
  productoRepoRinde     String?         // Producto reposición rinde
  
  // Tipo de trabajo
  tipoTrabajo           TipoTrabajoProducto @default(NINGUNO)  // LAMA, MR, NINGUNO
  
  // Idioma de etiqueta
  idiomaEtiqueta        IdiomaEtiqueta  @default(ESPAÑOL)
  
  // Temperatura y transporte
  temperaturaTransporte TemperaturaTransporte @default(CONGELADA)
  
  // Tipo de consumo
  tipoConsumo           TipoConsumo     @default(HUMANO)
  empresa               TipoEmpresa     @default(PROPIA)
  
  // Jaslo
  jaslo                 Boolean         @default(false)
  
  // Formato etiqueta
  formatoEtiqueta       String?         // FORMATO ETIQ.
  
  // Textos en etiqueta
  textoTipoTrabajo      String?         // TEXTO DE TIPO DE TRABAJO
  textoTipoCarne        String?         // TEXTO DE TIPO DE CARNE
  textoEspanol          String?         // TEXTO EN ESPAÑOL
  textoIngles           String?         // TEXTO EN INGLÉS
  textoTercerIdioma     String?         // TEXTO EN TERCER IDIOMA
  
  // Especie (para productos específicos)
  especie               Especie?
  
  // Configuración del código EAN-128 (parte fija)
  codigoTipificacion    String?         // 2 dígitos
  codigoTipoTrabajo     String?         // 1 dígito
  codigoTransporte      String?         // 1 dígito
  codigoDestino         String?         // 2 dígitos
  
  // Datos adicionales del modelo anterior
  diasConservacion      Int?
  tipoRotulo            TipoRotulo?
  precio                Float?
  temperaturaConservacion String?
  
  // Reportes
  apareceRendimiento    Boolean         @default(false)
  apareceStock          Boolean         @default(false)
  
  activo                Boolean         @default(true)
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  precios               PrecioProducto[]

  @@unique([codigo])
  @@index([especie])
  @@index([tipoTrabajo])
  @@index([activo])
}

enum TipoTrabajoProducto {
  LAMA
  MR
  NINGUNO
}

enum IdiomaEtiqueta {
  ESPAÑOL
  INGLES
  ITALIANO
  OTRO
}

enum TemperaturaTransporte {
  CONGELADA
  ENFRIADA_BUQUE
  ENFRIADA_AVION
}

enum TipoConsumo {
  HUMANO
  NO_HUMANO
}

enum TipoEmpresa {
  PROPIA
  OTRA
}

enum TipoRotulo {
  MEDIA_RES
  CUARTO
  MENUDENCIA
  PRODUCTO_TERMINADO_ENVASE_PRIMARIO
  PRODUCTO_TERMINADO_ENVASE_SECUNDARIO
  PRODUCTO_TERMINADO_UN_ENVASE
}

// ==================== TIPOS DE MENUDENCIAS ====================

model TipoMenudencia {
  id            String   @id @default(cuid())
  nombre        String   @unique
  activo        Boolean  @default(true)
  observaciones String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  menudencias   Menudencia[]
}

// ==================== RAZAS ====================

model Raza {
  id            String   @id @default(cuid())
  nombre        String
  especie       Especie
  activo        Boolean  @default(true)
  observaciones String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([nombre, especie])
}

// ==================== OPERADORES ====================

model Operador {
  id            String   @id @default(cuid())
  nombre        String
  usuario       String   @unique
  password      String   // Hash de la contraseña
  pin           String?  // PIN numérico opcional
  rol           RolOperador @default(OPERADOR)
  email         String?
  activo        Boolean  @default(true)
  
  // Permisos detallados
  puedePesajeCamiones     Boolean @default(true)
  puedePesajeIndividual   Boolean @default(true)
  puedeMovimientoHacienda Boolean @default(true)
  puedeListaFaena         Boolean @default(false)
  puedeRomaneo            Boolean @default(false)
  puedeMenudencias        Boolean @default(false)
  puedeStock              Boolean @default(false)
  puedeReportes           Boolean @default(false)
  puedeConfiguracion      Boolean @default(false)
  puedeFacturacion        Boolean @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relaciones
  pesajesCamion        PesajeCamion[]
  pesajesIndividuales  PesajeIndividual[]
  tropasCreadas        Tropa[]
  listasFaena          ListaFaena[]
  romaneos             Romaneo[]
  movimientosCorral    MovimientoCorral[]
  movimientosCamara    MovimientoCamara[]
  auditorias           Auditoria[]
}

enum RolOperador {
  OPERADOR
  SUPERVISOR
  ADMINISTRADOR
}

// ==================== CLIENTES / PROVEEDORES ====================

model Cliente {
  id              String   @id @default(cuid())
  nombre          String
  cuit            String?  @unique
  direccion       String?
  telefono        String?
  email           String?
  esProductor     Boolean  @default(false)
  esUsuarioFaena  Boolean  @default(false)
  
  // Campos para usuarios de faena (clientes del frigorífico)
  emails          String?  // Emails múltiples separados por ;
  celular         String?  // Celular de contacto
  contactoNombre  String?  // Nombre de persona de contacto
  modalidadRetiro Boolean  @default(false)  // true = retira en planta, false = envío
  
  // Precios de servicio (por kg)
  precioServicioSinRecupero Float?  // $/kg si deja menudencia al frigorífico
  precioServicioConRecupero Float?  // $/kg si lleva menudencia
  
  // Tipo de facturación
  tipoFacturacion String?  // "A", "B", "C" o null si no factura
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  tropasComoProductor    Tropa[]    @relation("ProductorTropas")
  tropasComoUsuarioFaena Tropa[]    @relation("UsuarioFaenaTropas")
  observaciones          ObservacionUsuario[]
  historicoPrecios       HistoricoPrecioUsuario[]
  facturas               FacturaServicio[]
}

// ==================== TRANSPORTISTAS ====================

model Transportista {
  id        String   @id @default(cuid())
  nombre    String
  cuit      String?  @unique
  direccion String?
  telefono  String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  pesajes   PesajeCamion[]
}

// ==================== TABLAS DE CÓDIGOS ====================

model CodigoEspecie {
  id          String   @id @default(cuid())
  codigo      String   @unique  // "1", "2", "6", etc.
  nombre      String            // "equino", "bovino", etc.
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CodigoTransporte {
  id          String   @id @default(cuid())
  codigo      String   @unique  // "0", "1", "2", etc.
  nombre      String            // "BARCO enfriado", etc.
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CodigoDestino {
  id          String   @id @default(cuid())
  codigo      String   @unique  // ".00", ".01", etc.
  nombre      String            // "Italia", "Francia", etc.
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CodigoTipoTrabajo {
  id          String   @id @default(cuid())
  codigo      String   @unique  // "0", "1", "2", etc.
  nombre      String            // "Ninguna", "descarte", etc.
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CodigoTipificacion {
  id          String   @id @default(cuid())
  codigo      String   @unique  // ".00", ".01", ".02", etc.
  nombre      String            // "todas", "M", "A", etc.
  especie     Especie           // Para qué especie aplica
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== TROPAS ====================

model Tropa {
  id              String      @id @default(cuid())
  numero          Int         @unique
  codigo          String      @unique   // Formato: "B 2026 0001" o "E 2026 0001"
  codigoSimplificado String?            // "B0001" para rótulos
  
  // Origen de los animales
  productorId     String?
  productor       Cliente?    @relation("ProductorTropas", fields: [productorId], references: [id])
  usuarioFaenaId  String
  usuarioFaena    Cliente     @relation("UsuarioFaenaTropas", fields: [usuarioFaenaId], references: [id])
  
  especie         Especie     @default(BOVINO)
  
  // Documentos de tránsito (OBLIGATORIOS)
  dte             String
  guia            String
  
  // Cantidad total
  cantidadCabezas Int
  
  // Tipos de animales (detalle)
  tiposAnimales   TropaAnimalCantidad[]
  
  // Corral asignado
  corralId        String?
  corral          Corral?     @relation(fields: [corralId], references: [id])
  
  // Estado
  estado          EstadoTropa @default(RECIBIDO)
  
  // Pesos (del pesaje de camión)
  pesoBruto       Float?
  pesoTara        Float?
  pesoNeto        Float?
  
  // Pesaje individual (suma de animales pesados)
  pesoTotalIndividual Float?
  
  observaciones   String?
  fechaRecepcion  DateTime    @default(now())
  
  // Operador que registró
  operadorId      String?
  operador        Operador?   @relation(fields: [operadorId], references: [id])
  
  // Relación con pesaje de camión
  pesajeCamionId  String?     @unique
  pesajeCamion    PesajeCamion?  @relation(fields: [pesajeCamionId], references: [id])
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  animales        Animal[]
  listasFaena     ListaFaenaTropa[]
  
  @@index([especie])
  @@index([estado])
  @@index([fechaRecepcion])
}

// Detalle de tipos de animales por tropa
model TropaAnimalCantidad {
  id          String   @id @default(cuid())
  tropaId     String
  tropa       Tropa    @relation(fields: [tropaId], references: [id], onDelete: Cascade)
  tipoAnimal  TipoAnimal
  cantidad    Int
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([tropaId, tipoAnimal])
}

enum Especie {
  BOVINO
  EQUINO
}

enum TipoAnimal {
  // Bovinos
  TO    // Toro
  VA    // Vaca
  VQ    // Vaquillona
  MEJ   // Torito/Mej
  NO    // Novillo
  NT    // Novillito
  
  // Equinos
  PADRILLO
  POTRILLO
  YEGUA
  CABALLO
  BURRO
  MULA
}

enum EstadoTropa {
  RECIBIDO
  EN_CORRAL
  EN_PESAJE
  PESADO
  LISTO_FAENA
  EN_FAENA
  FAENADO
  DESPACHADO
}

// ==================== ANIMALES ====================

model Animal {
  id             String       @id @default(cuid())
  tropaId        String
  tropa          Tropa        @relation(fields: [tropaId], references: [id])
  
  numero         Int          // Número secuencial dentro de la tropa
  codigo         String       @unique // Código completo: B20260001-001
  
  // Identificación
  caravana       String?      // Número de caravana/arete
  tipoAnimal     TipoAnimal
  raza           String?      // Raza del animal (Angus, Hereford, etc.)
  
  pesoVivo       Float?       // Peso en pie (del pesaje individual)
  
  estado         EstadoAnimal @default(RECIBIDO)
  corralId       String?      // Corral actual (para movimientos)
  
  // Baja/Fallecimiento
  fechaBaja      DateTime?
  motivoBaja     String?
  pesoBaja       Float?
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  pesajeIndividual PesajeIndividual?
  asignacionGarron  AsignacionGarron?
  
  @@unique([tropaId, numero])
  @@index([estado])
}

enum EstadoAnimal {
  RECIBIDO
  PESADO
  EN_FAENA
  FAENADO
  EN_CAMARA
  DESPACHADO
  FALLECIDO
}

// ==================== MOVIMIENTOS DE CORRAL ====================

model MovimientoCorral {
  id            String   @id @default(cuid())
  tropaId       String?
  animalId      String?
  
  corralOrigenId  String?
  corralOrigen    Corral?  @relation("CorralOrigen", fields: [corralOrigenId], references: [id])
  corralDestinoId String
  corralDestino   Corral   @relation("CorralDestino", fields: [corralDestinoId], references: [id])
  
  cantidad      Int      @default(1)
  especie       Especie?
  observaciones String?
  
  operadorId    String?
  operador      Operador? @relation(fields: [operadorId], references: [id])
  
  fecha         DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([fecha])
}

// ==================== PESAJE CAMIÓN ====================

model PesajeCamion {
  id              String          @id @default(cuid())
  tipo            TipoPesajeCamion @default(INGRESO_HACIENDA)
  numeroTicket    Int             @unique
  
  // Datos del vehículo
  patenteChasis   String
  patenteAcoplado String?
  
  // Chofer
  choferNombre    String?
  choferDni       String?
  
  // Transportista
  transportistaId String?
  transportista   Transportista?  @relation(fields: [transportistaId], references: [id])
  
  // Para Ingreso de Hacienda
  tropa           Tropa?
  
  // Para Salida de Mercadería
  destino         String?
  remito          String?
  factura         String?
  precintos       String?         // Números de precinto separados por coma
  
  // Pesos
  pesoBruto       Float?
  pesoTara        Float?
  pesoNeto        Float?
  
  // Para pesaje particular
  observaciones   String?
  
  // Estado
  estado          EstadoPesaje    @default(ABIERTO)
  
  // Operador
  operadorId      String?
  operador        Operador?       @relation(fields: [operadorId], references: [id])
  
  fecha           DateTime        @default(now())
  fechaTara       DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([tipo])
  @@index([estado])
  @@index([fecha])
}

enum TipoPesajeCamion {
  INGRESO_HACIENDA
  PESAJE_PARTICULAR
  SALIDA_MERCADERIA
}

enum EstadoPesaje {
  ABIERTO
  CERRADO
  ANULADO
}

// ==================== PESAJE INDIVIDUAL ====================

model PesajeIndividual {
  id            String     @id @default(cuid())
  animalId      String     @unique
  animal        Animal     @relation(fields: [animalId], references: [id])
  
  peso          Float
  caravana      String?    // Si se lee automáticamente
  observaciones String?
  
  operadorId    String?
  operador      Operador?  @relation(fields: [operadorId], references: [id])
  
  fecha         DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  @@index([fecha])
}

// ==================== LISTA DE FAENA ====================

model ListaFaena {
  id            String          @id @default(cuid())
  fecha         DateTime        @default(now())  // Una por día
  estado        EstadoListaFaena @default(ABIERTA)
  
  cantidadTotal Int             @default(0)
  
  supervisorId  String?         // Quien cierra la lista
  supervisor    Operador?       @relation(fields: [supervisorId], references: [id])
  fechaCierre   DateTime?
  
  observaciones String?
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  tropas        ListaFaenaTropa[]
  asignaciones  AsignacionGarron[]
  
  @@index([fecha])
  @@index([estado])
}

model ListaFaenaTropa {
  id            String   @id @default(cuid())
  listaFaenaId  String
  listaFaena    ListaFaena @relation(fields: [listaFaenaId], references: [id], onDelete: Cascade)
  
  tropaId       String
  tropa         Tropa    @relation(fields: [tropaId], references: [id])
  
  cantidad      Int      // Cantidad de animales de esta tropa a faenar
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([listaFaenaId, tropaId])
}

enum EstadoListaFaena {
  ABIERTA
  EN_PROCESO
  CERRADA
  ANULADA
}

// ==================== ASIGNACIÓN DE GARRÓN ====================

model AsignacionGarron {
  id            String       @id @default(cuid())
  listaFaenaId  String
  listaFaena    ListaFaena   @relation(fields: [listaFaenaId], references: [id])
  
  garron        Int          // Número de garrón (correlativo por día)
  
  animalId      String?      @unique  // Null si no se asignó animal
  animal        Animal?      @relation(fields: [animalId], references: [id])
  
  // Datos al momento de la asignación (se pueden modificar)
  numeroAnimal  Int?         // Número del animal dentro de la tropa (null si sin asignar)
  
  // Hora de ingreso a faena
  horaIngreso   DateTime     @default(now())
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  @@unique([listaFaenaId, garron])
  @@index([garron])
}

// ==================== ROMANEO ====================

model Romaneo {
  id                String        @id @default(cuid())
  listaFaenaId      String?
  fecha             DateTime      @default(now())
  
  // Datos del animal
  garron            Int
  tropaCodigo       String?
  numeroAnimal      Int?
  tipoAnimal        TipoAnimal?
  raza              String?
  pesoVivo          Float?        // KG ingreso
  
  // Tipificación
  denticion        String?        // Cantidad de dientes
  tipificadorId    String?
  tipificador      Tipificador?  @relation(fields: [tipificadorId], references: [id])
  
  // Pesos de medias reses
  pesoMediaIzq      Float?
  pesoMediaDer      Float?
  pesoTotal         Float?        // Suma de ambas medias
  
  // Rinde
  rinde             Float?        // Porcentaje
  
  // Estado
  estado            EstadoRomaneo @default(PENDIENTE)
  supervisorId      String?       // Quien confirma
  fechaConfirmacion DateTime?
  emailEnviado      Boolean       @default(false)
  
  operadorId        String?
  operador          Operador?     @relation(fields: [operadorId], references: [id])
  
  observaciones     String?
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  mediasRes         MediaRes[]
  
  @@index([fecha])
  @@index([garron])
  @@index([estado])
}

enum EstadoRomaneo {
  PENDIENTE
  CONFIRMADO
  ANULADO
}

// ==================== MEDIAS RESES ====================

model MediaRes {
  id            String       @id @default(cuid())
  romaneoId     String
  romaneo       Romaneo      @relation(fields: [romaneoId], references: [id])
  
  lado          LadoMedia    // IZQUIERDA o DERECHA
  peso          Float
  sigla         SiglaMedia   @default(A)  // A, T, D
  
  // Código de barras
  codigo        String       @unique
  
  // Estado
  estado        EstadoMediaRes @default(EN_CAMARA)
  
  // Cámara
  camaraId      String?
  camara        Camara?      @relation(fields: [camaraId], references: [id])
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  @@unique([romaneoId, lado, sigla])
  @@index([estado])
}

enum LadoMedia {
  IZQUIERDA
  DERECHA
}

enum SiglaMedia {
  A   // Asado
  T   // Trasero
  D   // Delantero
}

enum EstadoMediaRes {
  EN_CAMARA
  EN_CUARTEO
  DESPACHADO
}

// ==================== STOCK CÁMARA ====================

model StockMediaRes {
  id            String   @id @default(cuid())
  camaraId      String
  camara        Camara   @relation(fields: [camaraId], references: [id])
  
  tropaCodigo   String?
  especie       Especie
  
  cantidad      Int      @default(0)
  pesoTotal     Float    @default(0)
  
  fechaIngreso  DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([camaraId, tropaCodigo, especie])
}

// ==================== MOVIMIENTOS DE CÁMARA ====================

model MovimientoCamara {
  id              String   @id @default(cuid())
  
  camaraOrigenId  String?
  camaraOrigen    Camara?  @relation("CamaraOrigen", fields: [camaraOrigenId], references: [id])
  camaraDestinoId String?
  camaraDestino   Camara?  @relation("CamaraDestino", fields: [camaraDestinoId], references: [id])
  
  producto        String?  // Qué se movió
  cantidad        Int?
  peso            Float?
  
  // Trazabilidad
  tropaCodigo     String?
  mediaResId      String?
  
  operadorId      String?
  operador        Operador? @relation(fields: [operadorId], references: [id])
  
  observaciones   String?
  fecha           DateTime @default(now())
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([fecha])
}

// ==================== SUBPRODUCTOS ====================

model Subproducto {
  id            String   @id @default(cuid())
  codigo        String   @unique  // Código corto (CUERO, SEBO, etc.)
  nombre        String             // Nombre completo
  unidad        String   @default("kg")  // kg, unidades, etc.
  activo        Boolean  @default(true)
  observaciones String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  registros     RegistroSubproducto[]
  precios       PrecioSubproducto[]

  @@index([activo])
}

model RegistroSubproducto {
  id            String   @id @default(cuid())
  subproductoId String
  subproducto   Subproducto @relation(fields: [subproductoId], references: [id])

  tropaCodigo   String?   // De qué tropa proviene
  garron        Int?      // Si aplica a un animal específico

  cantidad      Float     // Cantidad registrada
  peso          Float?    // Peso en kg si aplica

  operadorId    String?
  observaciones String?

  fecha         DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([subproductoId])
  @@index([tropaCodigo])
  @@index([fecha])
}

// ==================== DECOMISOS ====================

model Decomiso {
  id            String   @id @default(cuid())
  garron        Int       // Número de garrón
  tropaCodigo   String?   // Código de tropa

  tipo          TipoDecomiso
  parte         String?   // Parte afectada (total, media res, cuarto, órgano)
  motivo        String    // Motivo del decomiso

  peso          Float?    // Peso del decomiso

  // Trazabilidad
  mediaResId    String?   // Si es parcial, qué media res
  romaneoId     String?   // Romaneo relacionado

  operadorId    String?
  observaciones String?

  fecha         DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([garron])
  @@index([tipo])
  @@index([fecha])
}

enum TipoDecomiso {
  TOTAL       // Animal completo
  PARCIAL     // Parte del animal
}

// ==================== PRECIOS CON HISTÓRICO ====================

model PrecioProducto {
  id            String   @id @default(cuid())
  productoId    String
  producto      Producto @relation(fields: [productoId], references: [id])

  precio        Float    // Precio al momento del registro
  fechaVigencia DateTime @default(now())  // Desde cuándo aplica este precio

  observaciones String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productoId])
  @@index([fechaVigencia])
}

model PrecioSubproducto {
  id            String      @id @default(cuid())
  subproductoId String
  subproducto   Subproducto @relation(fields: [subproductoId], references: [id])

  precio        Float       // Precio por unidad/kg
  fechaVigencia DateTime    @default(now())

  observaciones String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([subproductoId])
  @@index([fechaVigencia])
}

// ==================== MENUDENCIAS ====================

model Menudencia {
  id                String           @id @default(cuid())
  tipoMenudenciaId  String
  tipoMenudencia    TipoMenudencia   @relation(fields: [tipoMenudenciaId], references: [id])
  
  tropaCodigo       String?
  
  // Pesos
  pesoIngreso       Float?           // KG al ingresar a cámara
  pesoElaborado     Float?           // KG después de elaboración
  
  // Bolsas
  numeroBolsa       Int?
  cantidadBolsas    Int?
  
  // Operadores
  operadorElaboracion String?
  
  fechaIngreso      DateTime         @default(now())
  fechaElaboracion  DateTime?
  
  // Rótulo
  rotuloImpreso     Boolean          @default(false)
  
  observaciones     String?
  
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  @@index([tropaCodigo])
  @@index([fechaIngreso])
}

// ==================== AUDITORÍA ====================

model Auditoria {
  id            String   @id @default(cuid())
  operadorId    String?
  operador      Operador? @relation(fields: [operadorId], references: [id])
  
  modulo        String
  accion        String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  entidad       String
  entidadId     String?
  descripcion   String
  datosAntes    String?  // JSON
  datosDespues  String?  // JSON
  
  fecha         DateTime @default(now())
  ip            String?
  
  @@index([modulo])
  @@index([fecha])
}

// ==================== NUMERADORES ====================

model Numerador {
  id            String   @id @default(cuid())
  nombre        String   @unique  // "TROPA_BOVINO", "TROPA_EQUINO", "TICKET", etc.
  ultimoNumero  Int      @default(0)
  anio          Int?
  
  updatedAt     DateTime @updatedAt
}

// ==================== ARTÍCULOS (CÓDIGOS EAN-128) ====================

model Articulo {
  id            String   @id @default(cuid())
  codigo        String   @unique  // Código de 3 dígitos (.001, .002, etc.)
  nombre        String            // Nombre del artículo (lomo, bife angosto, etc.)
  categoria     String?           // CORTE, MENUDENCIA, PRODUCTO_PET, MEDIA_RES
  
  // Para generar código EAN-128
  especie       Especie?          // Si aplica a una especie específica
  activo        Boolean  @default(true)
  
  observaciones String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([categoria])
  @@index([activo])
}

// ==================== TIPOS DE TRABAJO (CORTES EQUINOS) ====================

model TipoTrabajo {
  id            String   @id @default(cuid())
  codigo        String   @unique  // "T/LAMA", "T/MR", "T/JASLO", "T/SQUARE", "T/CHECO"
  nombre        String            // Nombre completo
  descripcion   String?
  esDefault     Boolean  @default(false)  // T/MR es el default
  activo        Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==================== OBSERVACIONES POR USUARIO ====================

model ObservacionUsuario {
  id            String   @id @default(cuid())
  clienteId     String
  cliente       Cliente  @relation(fields: [clienteId], references: [id])
  
  fecha         DateTime @default(now())
  
  // Tipo de observación
  tipo          TipoObservacion @default(NOTA)
  
  observacion   String   // Texto de la observación/reclamo
  
  // Seguimiento
  fechaSeguimiento DateTime?  // Fecha para seguimiento futuro
  resuelto      Boolean  @default(false)
  fechaResolucion DateTime?
  resolucion    String?  // Texto de cómo se resolvió
  
  operadorId    String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([clienteId])
  @@index([fecha])
  @@index([tipo])
}

enum TipoObservacion {
  NOTA          // Nota general
  RECLAMO       // Reclamo del cliente
  RECORDATORIO  // Recordatorio para seguimiento
  INCIDENTE     // Incidente registrado
}

// ==================== HISTÓRICO DE PRECIOS POR USUARIO ====================

model HistoricoPrecioUsuario {
  id            String   @id @default(cuid())
  clienteId     String
  cliente       Cliente  @relation(fields: [clienteId], references: [id])
  
  // Precios
  precioSinRecupero Float?  // $/kg sin recupero
  precioConRecupero Float?  // $/kg con recupero
  
  fechaVigencia DateTime @default(now())  // Desde cuándo aplican estos precios
  
  observaciones String?
  
  operadorId    String?  // Quién registró el cambio
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([clienteId])
  @@index([fechaVigencia])
}

// ==================== FACTURACIÓN DE SERVICIOS ====================

model FacturaServicio {
  id            String   @id @default(cuid())
  numero        String   @unique  // Número de factura (00001-00000001)
  fecha         DateTime @default(now())
  fechaVencimiento DateTime?
  
  clienteId     String
  cliente       Cliente  @relation(fields: [clienteId], references: [id])
  
  // Totales
  subtotal      Float    @default(0)  // Sin IVA
  iva           Float    @default(0)  // 21%
  total         Float    @default(0)  // Con IVA
  
  // Estado
  estado        EstadoFactura @default(PENDIENTE)
  fechaPago     DateTime?
  metodoPago    String?  // Efectivo, Transferencia, Cheque, etc.
  
  // Observaciones
  observaciones String?
  
  operadorId    String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  detalles      DetalleFacturaServicio[]
  
  @@index([clienteId])
  @@index([fecha])
  @@index([estado])
}

model DetalleFacturaServicio {
  id            String   @id @default(cuid())
  facturaId     String
  factura       FacturaServicio @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  
  tropaId       String?  // Tropa facturada
  tropaCodigo   String?  // Código de tropa para referencia
  
  // Datos del servicio
  cantidadAnimales Int   @default(0)
  kgGancho      Float    @default(0)  // Total kg gancho
  
  // Servicios
  servicioFaena Float    @default(0)
  servicioDespostada Float @default(0)
  
  // Recuperos (si no lleva menudencia)
  ventaMenudencia Float  @default(0)
  ventaHueso    Float    @default(0)
  ventaGrasa    Float    @default(0)
  ventaCuero    Float    @default(0)
  
  // Totales
  subtotal      Float    @default(0)
  
  observaciones String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([facturaId])
  @@index([tropaCodigo])
}

enum EstadoFactura {
  PENDIENTE
  PAGADA
  ANULADA
  VENCIDA
}

// ==================== REGISTRO DE MENUDENCIAS POR TROPA ====================

model RegistroMenudencia {
  id            String   @id @default(cuid())
  tropaCodigo   String
  tropaId       String?
  
  fecha         DateTime @default(now())
  
  // Artículo de menudencia
  articulo      String   // CHINCHULIN, CORAZON, HIGADO, etc.
  
  // Pesos
  kgCamara      Float    @default(0)  // KG guardados en cámara
  kgElaborado   Float    @default(0)  // KG elaborados
  
  // Bolsas
  cantidadBolsas Int     @default(0)
  
  // Usuario/Cliente
  clienteId     String?
  
  operadorId    String?
  observaciones String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([tropaCodigo])
  @@index([fecha])
}

// ==================== PESAJE INTERNO (MENUDENCIAS) ====================

model PesajeInterno {
  id            String   @id @default(cuid())
  tropaCodigo   String
  fecha         DateTime @default(now())
  
  // Pesaje interno
  grasa         Float    @default(0)
  lavadito      Float    @default(0)
  bolsaAzul     Float    @default(0)
  
  // Pesaje báscula (manitou)
  hueso         Float    @default(0)
  grasaBascula  Float    @default(0)
  despojo       Float    @default(0)
  
  operadorId    String?
  observaciones String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([tropaCodigo])
  @@index([fecha])
}
