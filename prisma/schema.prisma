generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Animal {
  id               String            @id @default(cuid())
  tropaId          String
  numero           Int
  codigo           String            @unique
  caravana         String?
  tipoAnimal       String
  raza             String?
  pesoVivo         Float?
  estado           String            @default("RECIBIDO")
  corralId         String?
  fechaBaja        DateTime?
  motivoBaja       String?
  pesoBaja         Float?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  Tropa            Tropa             @relation(fields: [tropaId], references: [id])
  AsignacionGarron AsignacionGarron?
  PesajeIndividual PesajeIndividual?

  @@unique([tropaId, numero])
  @@index([estado])
}

model Articulo {
  id            String   @id @default(cuid())
  codigo        String   @unique
  nombre        String
  categoria     String?
  especie       String?
  activo        Boolean  @default(true)
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime

  @@index([activo])
  @@index([categoria])
}

model AsignacionGarron {
  id           String     @id @default(cuid())
  listaFaenaId String
  garron       Int
  animalId     String?    @unique
  numeroAnimal Int?
  horaIngreso  DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  Animal       Animal?    @relation(fields: [animalId], references: [id])
  ListaFaena   ListaFaena @relation(fields: [listaFaenaId], references: [id])

  @@unique([listaFaenaId, garron])
  @@index([garron])
}

model Auditoria {
  id           String    @id @default(cuid())
  operadorId   String?
  modulo       String
  accion       String
  entidad      String
  entidadId    String?
  descripcion  String
  datosAntes   String?
  datosDespues String?
  fecha        DateTime  @default(now())
  ip           String?
  Operador     Operador? @relation(fields: [operadorId], references: [id])

  @@index([fecha])
  @@index([modulo])
}

model AutorizacionOperacion {
  id                 String   @id @default(cuid())
  operadorId         String
  modulo             String
  accion             String
  entidadId          String?
  autorizadoPorId    String?
  metodoAutorizacion String?
  observaciones      String?
  fecha              DateTime @default(now())
  createdAt          DateTime @default(now())
  Operador           Operador @relation(fields: [operadorId], references: [id])

  @@index([fecha])
  @@index([modulo])
  @@index([operadorId])
}

model Camara {
  id                                                        String             @id
  nombre                                                    String             @unique
  tipo                                                      String             @default("FAENA")
  capacidad                                                 Int                @default(0)
  observaciones                                             String?
  activo                                                    Boolean            @default(true)
  createdAt                                                 DateTime           @default(now())
  updatedAt                                                 DateTime
  MediaRes                                                  MediaRes[]
  MovimientoCamara_MovimientoCamara_camaraDestinoIdToCamara MovimientoCamara[] @relation("MovimientoCamara_camaraDestinoIdToCamara")
  MovimientoCamara_MovimientoCamara_camaraOrigenIdToCamara  MovimientoCamara[] @relation("MovimientoCamara_camaraOrigenIdToCamara")
  StockMediaRes                                             StockMediaRes[]
}

model Cliente {
  id                                  String                   @id
  nombre                              String
  cuit                                String?                  @unique
  direccion                           String?
  telefono                            String?
  email                               String?
  esProductor                         Boolean                  @default(false)
  esUsuarioFaena                      Boolean                  @default(false)
  emails                              String?
  celular                             String?
  contactoNombre                      String?
  modalidadRetiro                     Boolean                  @default(false)
  precioServicioSinRecupero           Float?
  precioServicioConRecupero           Float?
  tipoFacturacion                     String?
  createdAt                           DateTime                 @default(now())
  updatedAt                           DateTime
  FacturaServicio                     FacturaServicio[]
  HistoricoPrecioUsuario              HistoricoPrecioUsuario[]
  ObservacionUsuario                  ObservacionUsuario[]
  Tropa_Tropa_usuarioFaenaIdToCliente Tropa[]                  @relation("Tropa_usuarioFaenaIdToCliente")
  Tropa_Tropa_productorIdToCliente    Tropa[]                  @relation("Tropa_productorIdToCliente")
}

model CodigoDestino {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model CodigoEspecie {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model CodigoTipificacion {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  especie   String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model CodigoTipoTrabajo {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model CodigoTransporte {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model ConfiguracionFrigorifico {
  id                    String   @id @default(cuid())
  nombre                String   @default("Solemar Alimentaria")
  direccion             String?
  numeroEstablecimiento String?
  cuit                  String?
  numeroMatricula       String?
  logo                  String?
  emailHost             String?
  emailPuerto           Int?     @default(587)
  emailUsuario          String?
  emailPassword         String?
  emailHabilitado       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime
}

model Corral {
  id                                                        String             @id @default(cuid())
  nombre                                                    String             @unique
  capacidad                                                 Int                @default(0)
  observaciones                                             String?
  activo                                                    Boolean            @default(true)
  stockBovinos                                              Int                @default(0)
  stockEquinos                                              Int                @default(0)
  createdAt                                                 DateTime           @default(now())
  updatedAt                                                 DateTime           @updatedAt
  MovimientoCorral_MovimientoCorral_corralDestinoIdToCorral MovimientoCorral[] @relation("MovimientoCorral_corralDestinoIdToCorral")
  MovimientoCorral_MovimientoCorral_corralOrigenIdToCorral  MovimientoCorral[] @relation("MovimientoCorral_corralOrigenIdToCorral")
  Tropa                                                     Tropa[]
}

model Decomiso {
  id            String   @id @default(cuid())
  garron        Int
  tropaCodigo   String?
  tipo          String
  parte         String?
  motivo        String
  peso          Float?
  mediaResId    String?
  romaneoId     String?
  operadorId    String?
  observaciones String?
  fecha         DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime

  @@index([fecha])
  @@index([tipo])
  @@index([garron])
}

model DetalleFacturaServicio {
  id                 String          @id
  facturaId          String
  tropaId            String?
  tropaCodigo        String?
  cantidadAnimales   Int             @default(0)
  kgGancho           Float           @default(0)
  servicioFaena      Float           @default(0)
  servicioDespostada Float           @default(0)
  ventaMenudencia    Float           @default(0)
  ventaHueso         Float           @default(0)
  ventaGrasa         Float           @default(0)
  ventaCuero         Float           @default(0)
  subtotal           Float           @default(0)
  observaciones      String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime
  FacturaServicio    FacturaServicio @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  @@index([tropaCodigo])
  @@index([facturaId])
}

model FacturaServicio {
  id                     String                   @id
  numero                 String                   @unique
  fecha                  DateTime                 @default(now())
  fechaVencimiento       DateTime?
  clienteId              String
  subtotal               Float                    @default(0)
  iva                    Float                    @default(0)
  total                  Float                    @default(0)
  estado                 String                   @default("PENDIENTE")
  fechaPago              DateTime?
  metodoPago             String?
  observaciones          String?
  operadorId             String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  DetalleFacturaServicio DetalleFacturaServicio[]
  Cliente                Cliente                  @relation(fields: [clienteId], references: [id])

  @@index([estado])
  @@index([fecha])
  @@index([clienteId])
}

model HistoricoPrecioUsuario {
  id                String   @id @default(cuid())
  clienteId         String
  precioSinRecupero Float?
  precioConRecupero Float?
  fechaVigencia     DateTime @default(now())
  observaciones     String?
  operadorId        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  Cliente           Cliente  @relation(fields: [clienteId], references: [id])

  @@index([fechaVigencia])
  @@index([clienteId])
}

model ListaFaena {
  id               String             @id
  fecha            DateTime           @default(now())
  estado           String             @default("ABIERTA")
  cantidadTotal    Int                @default(0)
  supervisorId     String?
  fechaCierre      DateTime?
  observaciones    String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  AsignacionGarron AsignacionGarron[]
  Operador         Operador?          @relation(fields: [supervisorId], references: [id])
  ListaFaenaTropa  ListaFaenaTropa[]

  @@index([estado])
  @@index([fecha])
}

model ListaFaenaTropa {
  id           String     @id @default(cuid())
  listaFaenaId String
  tropaId      String
  cantidad     Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  Tropa        Tropa      @relation(fields: [tropaId], references: [id])
  ListaFaena   ListaFaena @relation(fields: [listaFaenaId], references: [id], onDelete: Cascade)

  @@unique([listaFaenaId, tropaId])
}

model MediaRes {
  id        String   @id @default(cuid())
  romaneoId String
  lado      String
  peso      Float
  sigla     String   @default("A")
  codigo    String   @unique
  estado    String   @default("EN_CAMARA")
  camaraId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  Camara    Camara?  @relation(fields: [camaraId], references: [id])
  Romaneo   Romaneo  @relation(fields: [romaneoId], references: [id])

  @@unique([romaneoId, lado, sigla])
  @@index([estado])
}

model Menudencia {
  id                  String         @id @default(cuid())
  tipoMenudenciaId    String
  tropaCodigo         String?
  pesoIngreso         Float?
  pesoElaborado       Float?
  numeroBolsa         Int?
  cantidadBolsas      Int?
  operadorElaboracion String?
  fechaIngreso        DateTime       @default(now())
  fechaElaboracion    DateTime?
  rotuloImpreso       Boolean        @default(false)
  observaciones       String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime
  TipoMenudencia      TipoMenudencia @relation(fields: [tipoMenudenciaId], references: [id])

  @@index([fechaIngreso])
  @@index([tropaCodigo])
}

model MovimientoCamara {
  id                                              String    @id
  camaraOrigenId                                  String?
  camaraDestinoId                                 String?
  producto                                        String?
  cantidad                                        Int?
  peso                                            Float?
  tropaCodigo                                     String?
  mediaResId                                      String?
  operadorId                                      String?
  observaciones                                   String?
  fecha                                           DateTime  @default(now())
  createdAt                                       DateTime  @default(now())
  updatedAt                                       DateTime
  Operador                                        Operador? @relation(fields: [operadorId], references: [id])
  Camara_MovimientoCamara_camaraDestinoIdToCamara Camara?   @relation("MovimientoCamara_camaraDestinoIdToCamara", fields: [camaraDestinoId], references: [id])
  Camara_MovimientoCamara_camaraOrigenIdToCamara  Camara?   @relation("MovimientoCamara_camaraOrigenIdToCamara", fields: [camaraOrigenId], references: [id])

  @@index([fecha])
}

model MovimientoCorral {
  id                                              String    @id
  tropaId                                         String?
  animalId                                        String?
  corralOrigenId                                  String?
  corralDestinoId                                 String
  cantidad                                        Int       @default(1)
  especie                                         String?
  observaciones                                   String?
  operadorId                                      String?
  fecha                                           DateTime  @default(now())
  createdAt                                       DateTime  @default(now())
  updatedAt                                       DateTime
  Operador                                        Operador? @relation(fields: [operadorId], references: [id])
  Corral_MovimientoCorral_corralDestinoIdToCorral Corral    @relation("MovimientoCorral_corralDestinoIdToCorral", fields: [corralDestinoId], references: [id])
  Corral_MovimientoCorral_corralOrigenIdToCorral  Corral?   @relation("MovimientoCorral_corralOrigenIdToCorral", fields: [corralOrigenId], references: [id])

  @@index([fecha])
}

model Numerador {
  id           String   @id @default(cuid())
  nombre       String   @unique
  ultimoNumero Int      @default(0)
  anio         Int?
  updatedAt    DateTime
}

model ObservacionUsuario {
  id               String    @id
  clienteId        String
  fecha            DateTime  @default(now())
  tipo             String    @default("NOTA")
  observacion      String
  fechaSeguimiento DateTime?
  resuelto         Boolean   @default(false)
  fechaResolucion  DateTime?
  resolucion       String?
  operadorId       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime
  Cliente          Cliente   @relation(fields: [clienteId], references: [id])

  @@index([tipo])
  @@index([fecha])
  @@index([clienteId])
}

model Operador {
  id                    String                  @id
  nombre                String
  usuario               String                  @unique
  password              String
  pin                   String?
  email                 String?
  activo                Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  Auditoria             Auditoria[]
  AutorizacionOperacion AutorizacionOperacion[]
  ListaFaena            ListaFaena[]
  MovimientoCamara      MovimientoCamara[]
  MovimientoCorral      MovimientoCorral[]
  PermisoModulo         PermisoModulo[]
  PesajeCamion          PesajeCamion[]
  PesajeIndividual      PesajeIndividual[]
  Romaneo               Romaneo[]
  Tropa                 Tropa[]
}

model PermisoModulo {
  id         String   @id @default(cuid())
  operadorId String
  modulo     String
  nivel      String   @default("OPERADOR")
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Operador   Operador @relation(fields: [operadorId], references: [id], onDelete: Cascade)

  @@unique([operadorId, modulo])
  @@index([modulo])
}

model PesajeCamion {
  id              String         @id @default(cuid())
  tipo            String         @default("INGRESO_HACIENDA")
  numeroTicket    Int            @unique
  patenteChasis   String
  patenteAcoplado String?
  choferNombre    String?
  choferDni       String?
  transportistaId String?
  destino         String?
  remito          String?
  factura         String?
  precintos       String?
  pesoBruto       Float?
  pesoTara        Float?
  pesoNeto        Float?
  observaciones   String?
  estado          String         @default("ABIERTO")
  operadorId      String?
  fecha           DateTime       @default(now())
  fechaTara       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  Operador        Operador?      @relation(fields: [operadorId], references: [id])
  Transportista   Transportista? @relation(fields: [transportistaId], references: [id])
  Tropa           Tropa?

  @@index([fecha])
  @@index([estado])
  @@index([tipo])
}

model PesajeIndividual {
  id            String    @id
  animalId      String    @unique
  peso          Float
  caravana      String?
  observaciones String?
  operadorId    String?
  fecha         DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Operador      Operador? @relation(fields: [operadorId], references: [id])
  Animal        Animal    @relation(fields: [animalId], references: [id])

  @@index([fecha])
}

model PesajeInterno {
  id            String   @id @default(cuid())
  tropaCodigo   String
  fecha         DateTime @default(now())
  grasa         Float    @default(0)
  lavadito      Float    @default(0)
  bolsaAzul     Float    @default(0)
  hueso         Float    @default(0)
  grasaBascula  Float    @default(0)
  despojo       Float    @default(0)
  operadorId    String?
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime

  @@index([fecha])
  @@index([tropaCodigo])
}

model PrecioProducto {
  id            String   @id @default(cuid())
  productoId    String
  precio        Float
  fechaVigencia DateTime @default(now())
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  Producto      Producto @relation(fields: [productoId], references: [id])

  @@index([fechaVigencia])
  @@index([productoId])
}

model PrecioSubproducto {
  id            String      @id
  subproductoId String
  precio        Float
  fechaVigencia DateTime    @default(now())
  observaciones String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  Subproducto   Subproducto @relation(fields: [subproductoId], references: [id])

  @@index([fechaVigencia])
  @@index([subproductoId])
}

model Producto {
  id                      String           @id
  codigo                  String           @unique
  codigoSecundario        String?
  nombre                  String
  tara                    Float?
  vencimiento             Int?
  nroSenasa               String?
  unidad                  String?
  cantidadEtiquetas       Int?
  tieneTipificacion       Boolean          @default(false)
  tipificacion            String?
  tipificacionSecundaria  String?
  tipo                    String?
  tipoGeneral             String?
  descripcionCircular     String?
  precioDolar             Float?
  precioEuro              Float?
  producidoParaCliente    String?
  producidoDePieza        String?
  productoGeneral         String?
  productoRepoRinde       String?
  tipoTrabajo             String           @default("NINGUNO")
  idiomaEtiqueta          String           @default("ESPAÑOL")
  temperaturaTransporte   String           @default("CONGELADA")
  tipoConsumo             String           @default("HUMANO")
  empresa                 String           @default("PROPIA")
  jaslo                   Boolean          @default(false)
  formatoEtiqueta         String?
  textoTipoTrabajo        String?
  textoTipoCarne          String?
  textoEspanol            String?
  textoIngles             String?
  textoTercerIdioma       String?
  especie                 String?
  codigoTipificacion      String?
  codigoTipoTrabajo       String?
  codigoTransporte        String?
  codigoDestino           String?
  diasConservacion        Int?
  tipoRotulo              String?
  precio                  Float?
  temperaturaConservacion String?
  apareceRendimiento      Boolean          @default(false)
  apareceStock            Boolean          @default(false)
  activo                  Boolean          @default(true)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime
  PrecioProducto          PrecioProducto[]

  @@index([activo])
  @@index([tipoTrabajo])
  @@index([especie])
}

model Raza {
  id            String   @id @default(cuid())
  nombre        String
  especie       String
  activo        Boolean  @default(true)
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime

  @@unique([nombre, especie])
}

model RegistroMenudencia {
  id             String   @id @default(cuid())
  tropaCodigo    String
  tropaId        String?
  fecha          DateTime @default(now())
  articulo       String
  kgCamara       Float    @default(0)
  kgElaborado    Float    @default(0)
  cantidadBolsas Int      @default(0)
  clienteId      String?
  operadorId     String?
  observaciones  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime

  @@index([fecha])
  @@index([tropaCodigo])
}

model RegistroSubproducto {
  id            String      @id
  subproductoId String
  tropaCodigo   String?
  garron        Int?
  cantidad      Float
  peso          Float?
  operadorId    String?
  observaciones String?
  fecha         DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  Subproducto   Subproducto @relation(fields: [subproductoId], references: [id])

  @@index([fecha])
  @@index([tropaCodigo])
  @@index([subproductoId])
}

model Romaneo {
  id                String       @id
  listaFaenaId      String?
  fecha             DateTime     @default(now())
  garron            Int
  tropaCodigo       String?
  numeroAnimal      Int?
  tipoAnimal        String?
  raza              String?
  pesoVivo          Float?
  denticion         String?
  tipificadorId     String?
  pesoMediaIzq      Float?
  pesoMediaDer      Float?
  pesoTotal         Float?
  rinde             Float?
  estado            String       @default("PENDIENTE")
  supervisorId      String?
  fechaConfirmacion DateTime?
  emailEnviado      Boolean      @default(false)
  operadorId        String?
  observaciones     String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime
  MediaRes          MediaRes[]
  Operador          Operador?    @relation(fields: [operadorId], references: [id])
  Tipificador       Tipificador? @relation(fields: [tipificadorId], references: [id])

  @@index([estado])
  @@index([garron])
  @@index([fecha])
}

model StockMediaRes {
  id           String   @id @default(cuid())
  camaraId     String
  tropaCodigo  String?
  especie      String
  cantidad     Int      @default(0)
  pesoTotal    Float    @default(0)
  fechaIngreso DateTime @default(now())
  updatedAt    DateTime
  Camara       Camara   @relation(fields: [camaraId], references: [id])

  @@unique([camaraId, tropaCodigo, especie])
}

model Subproducto {
  id                  String                @id
  codigo              String                @unique
  nombre              String
  unidad              String                @default("kg")
  activo              Boolean               @default(true)
  observaciones       String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  PrecioSubproducto   PrecioSubproducto[]
  RegistroSubproducto RegistroSubproducto[]

  @@index([activo])
}

model Tipificador {
  id        String    @id
  nombre    String
  apellido  String
  numero    String?
  matricula String    @unique
  activo    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime
  Romaneo   Romaneo[]
}

model TipoMenudencia {
  id            String       @id
  nombre        String       @unique
  activo        Boolean      @default(true)
  observaciones String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime
  Menudencia    Menudencia[]
}

model TipoTrabajo {
  id          String   @id @default(cuid())
  codigo      String   @unique
  nombre      String
  descripcion String?
  esDefault   Boolean  @default(false)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model Transportista {
  id           String         @id @default(cuid())
  nombre       String
  cuit         String?        @unique
  direccion    String?
  telefono     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  PesajeCamion PesajeCamion[]
}

model Tropa {
  id                                    String                @id
  numero                                Int                   @unique
  codigo                                String                @unique
  codigoSimplificado                    String?
  productorId                           String?
  usuarioFaenaId                        String
  especie                               String                @default("BOVINO")
  dte                                   String
  guia                                  String
  cantidadCabezas                       Int
  corralId                              String?
  estado                                String                @default("RECIBIDO")
  pesoBruto                             Float?
  pesoTara                              Float?
  pesoNeto                              Float?
  pesoTotalIndividual                   Float?
  observaciones                         String?
  fechaRecepcion                        DateTime              @default(now())
  operadorId                            String?
  pesajeCamionId                        String?               @unique
  createdAt                             DateTime              @default(now())
  updatedAt                             DateTime
  Animal                                Animal[]
  ListaFaenaTropa                       ListaFaenaTropa[]
  PesajeCamion                          PesajeCamion?         @relation(fields: [pesajeCamionId], references: [id])
  Operador                              Operador?             @relation(fields: [operadorId], references: [id])
  Corral                                Corral?               @relation(fields: [corralId], references: [id])
  Cliente_Tropa_usuarioFaenaIdToCliente Cliente               @relation("Tropa_usuarioFaenaIdToCliente", fields: [usuarioFaenaId], references: [id])
  Cliente_Tropa_productorIdToCliente    Cliente?              @relation("Tropa_productorIdToCliente", fields: [productorId], references: [id])
  TropaAnimalCantidad                   TropaAnimalCantidad[]

  @@index([fechaRecepcion])
  @@index([estado])
  @@index([especie])
}

model TropaAnimalCantidad {
  id         String   @id @default(cuid())
  tropaId    String
  tipoAnimal String
  cantidad   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Tropa      Tropa    @relation(fields: [tropaId], references: [id], onDelete: Cascade)

  @@unique([tropaId, tipoAnimal])
}
